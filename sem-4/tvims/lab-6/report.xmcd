		</region>
		<region region-id="3970" left="576" top="1764.75" width="309.75" height="76.5" align-x="576" align-y="1776" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Вывод:</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">b<sub>0 </sub>
					<inlineAttr>значимо отличается от 0, т.к. </inlineAttr>|<region region-id="4035" left="740.25" top="1779.75" width="9.75" height="17.25" align-x="744" align-y="1791" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
						<math optimize="false" disable-calc="false">
							<ml:apply xmlns:ml="http://schemas.mathsoft.com/math30">
								<ml:indexer/>
								<ml:id xml:space="preserve">t</ml:id>
								<ml:real>0</ml:real>
							</ml:apply>
						</math>
						<rendering item-idref="30"/>
					</region>
					<f family="Times New Roman" charset="0" size="12">
						<inlineAttr font-weight="normal" font-style="normal" underline="false" line-through="false">| = 2.263 &gt; t_tabl = 2.262<sp count="2"/>
						</inlineAttr>
					</f>
				</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">b<sub>1</sub>
					<sub>
						<sp/>
					</sub>значимо отличается от 0, т.к. |<region region-id="4038" left="740.25" top="1802.25" width="9.75" height="17.25" align-x="744" align-y="1813.5" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
						<math optimize="false" disable-calc="false">
							<ml:apply xmlns:ml="http://schemas.mathsoft.com/math30">
								<ml:indexer/>
								<ml:id xml:space="preserve">t</ml:id>
								<ml:real>1</ml:real>
							</ml:apply>
						</math>
						<rendering item-idref="31"/>
					</region>
					<f family="Times New Roman" charset="0" size="12">
						<inlineAttr font-weight="normal" font-style="normal" underline="false" line-through="false">| </inlineAttr>
					</f>= 4.673 &gt; t_tabl = 2.262</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<f family="Times New Roman" charset="0" size="12">
						<inlineAttr font-weight="normal" font-style="normal" underline="false" line-through="false">b</inlineAttr>
					</f>
					<sub>
						<f family="Times New Roman" charset="0" size="12">
							<inlineAttr font-weight="normal" font-style="normal" underline="false" line-through="false">2 </inlineAttr>
						</f>
					</sub>
					<f family="Times New Roman" charset="0" size="12">
						<inlineAttr font-weight="normal" font-style="normal" underline="false" line-through="false">НЕ значимо отличается от 0</inlineAttr>
					</f>, т.к. |t<sub>2</sub>| = 1.142 &lt; t_tabl = 2.262</p>
			</text>
		</region>
		<region region-id="3971" left="576" top="1878.75" width="456" height="14.25" align-x="576" align-y="1890" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">

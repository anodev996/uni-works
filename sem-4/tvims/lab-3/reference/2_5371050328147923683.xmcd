		</region>
		<region region-id="111" left="24" top="780.75" width="110.25" height="29.25" align-x="61.5" align-y="798" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:id xml:space="preserve">interval</ml:id>
					<ml:matrix rows="2" cols="1">
						<ml:id xml:space="preserve">left_bound</ml:id>
						<ml:id xml:space="preserve">right_bound</ml:id>

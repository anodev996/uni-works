		<region region-id="180" left="168" top="656.25" width="268.5" height="24" align-x="168" align-y="666" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">это оценочное С.К.О достаточно близко к значению 0.2887, что соответсвует С.К.О равномерного распределения</p>
			</text>
		</region>
		<region region-id="84" left="18" top="661.5" width="95.25" height="14.25" align-x="30.75" align-y="672" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">

		<region region-id="170" left="144" top="830.25" width="289.5" height="24" align-x="153.75" align-y="840" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">60% чисел попали в интервал (m-σ; m+σ), что достаточно близко к 57.7%, характерным для равномерного распределения </p>
			</text>
		</region>
		<region region-id="116" left="24" top="830.25" width="111" height="27.75" align-x="96" align-y="846" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:apply>
						<ml:div/>
						<ml:apply>
							<ml:id xml:space="preserve">hist</ml:id>
							<ml:sequence>
								<ml:id xml:space="preserve">interval</ml:id>
								<ml:id xml:space="preserve">γ</ml:id>
							</ml:sequence>
						</ml:apply>
						<ml:id xml:space="preserve">n</ml:id>
					</ml:apply>
					<result xmlns="http://schemas.mathsoft.com/math30">
						<ml:matrix rows="1" cols="1">
							<ml:real>0.55</ml:real>
						</ml:matrix>
					</result>
				</ml:eval>
			</math>
			<rendering item-idref="16"/>
		</region>
		<region region-id="128" left="24" top="870.75" width="94.5" height="29.25" align-x="86.25" align-y="888" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:apply>
						<ml:id xml:space="preserve">hist</ml:id>
						<ml:sequence>
							<ml:matrix rows="2" cols="1">
								<ml:real>0</ml:real>
								<ml:real>0.5</ml:real>
							</ml:matrix>
							<ml:id xml:space="preserve">γ</ml:id>
						</ml:sequence>
					</ml:apply>
					<result xmlns="http://schemas.mathsoft.com/math30">
						<ml:matrix rows="1" cols="1">
							<ml:real>55</ml:real>
						</ml:matrix>
					</result>
				</ml:eval>
			</math>
			<rendering item-idref="17"/>
		</region>
		<region region-id="141" left="126" top="884.25" width="297.75" height="36" align-x="150" align-y="894" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Количество чисел, попавших в интервал (0; 0.5) примерно равно количеству чисел, попавших в интервал (0.5; 1). Погрешность в 6 будем считать результатом малой выборки.</p>
			</text>
		</region>
		<region region-id="132" left="24" top="912.75" width="94.5" height="29.25" align-x="86.25" align-y="930" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:apply>
						<ml:id xml:space="preserve">hist</ml:id>
						<ml:sequence>
							<ml:matrix rows="2" cols="1">
								<ml:real>0.5</ml:real>
								<ml:real>1</ml:real>
							</ml:matrix>
							<ml:id xml:space="preserve">γ</ml:id>
						</ml:sequence>
					</ml:apply>
					<result xmlns="http://schemas.mathsoft.com/math30">
						<ml:matrix rows="1" cols="1">
							<ml:real>46</ml:real>
						</ml:matrix>
					</result>
				</ml:eval>
			</math>
			<rendering item-idref="18"/>
		</region>
		<region region-id="152" left="30" top="957.75" width="246" height="18" align-x="42" align-y="972" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:id xml:space="preserve">f</ml:id>
					<ml:apply>
						<ml:id xml:space="preserve">hist</ml:id>
						<ml:sequence>
							<ml:apply>
								<ml:transpose/>
								<ml:matrix rows="1" cols="11">
									<ml:real>0</ml:real>
									<ml:real>0.1</ml:real>
									<ml:real>0.2</ml:real>
									<ml:real>0.3</ml:real>
									<ml:real>0.4</ml:real>
									<ml:real>0.5</ml:real>
									<ml:real>0.6</ml:real>
									<ml:real>0.7</ml:real>
									<ml:real>0.8</ml:real>
									<ml:real>0.9</ml:real>
									<ml:real>1</ml:real>
								</ml:matrix>
							</ml:apply>
							<ml:id xml:space="preserve">γ</ml:id>
						</ml:sequence>
					</ml:apply>
				</ml:define>
			</math>
			<rendering item-idref="19"/>
		</region>
		<region region-id="151" left="24" top="996" width="245.25" height="134.25" align-x="24" align-y="996" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">

		<region region-id="2479" left="564" top="918.75" width="54" height="34.5" align-x="569.25" align-y="930" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">

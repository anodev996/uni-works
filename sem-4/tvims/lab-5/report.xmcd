		<region region-id="2748" left="570" top="3330.75" width="357.75" height="14.25" align-x="570" align-y="3342" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Расчет коэффициента Пирсона для сгруппированных данных<sp count="2"/>
				</p>
